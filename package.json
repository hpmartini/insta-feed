{
  "name": "insta-feed",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build-prod": "ng build --prod",
    "build-emu": "ng build --c=emulator --watch",
    "test": "ng test",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "postinstall": "npm run install-functions",
    "install-functions": "cd functions && npm install",
    "emulate": "ng build --c=emulator && firbase emulators:start",
    "emulators": "firebase emulators:start --import=data --export-on-exit"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^18.0.0",
    "@angular/cdk": "^18.0.0",
